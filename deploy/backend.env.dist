# =============================================================================
# VEAF Website — Backend environment variables
# Copy this file to backend.env and fill in your production values.
# =============================================================================

# --- Database ----------------------------------------------------------------
# The PostgreSQL host must be reachable via the "database" Docker network.
DATABASE_URL=postgresql+asyncpg://veaf:CHANGE_ME@postgres-host:5432/veaf

# --- JWT authentication ------------------------------------------------------
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Email (SMTP) ------------------------------------------------------------
MAIL_FROM=noreply@veaf.org
MAIL_SERVER=maildev
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TLS=false

# --- External APIs ------------------------------------------------------------
API_DCSSERVERBOT_URL=http://dcs.veaf.org:9876
API_TEAMSPEAK_URL=serverquery://ts.veaf.org:10011/?server_port=9987

# --- Discord OAuth2 ----------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://veaf.org/auth/discord/callback

# --- reCAPTCHA v3 -------------------------------------------------------------
RECAPTCHA_SECRET_KEY=

# --- Application --------------------------------------------------------------
APP_URL=https://veaf.org
UPLOAD_DIR=./uploads
