# =============================================================================
# VEAF Website — Docker Compose environment variables
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Image tag ----------------------------------------------------------------
# Docker image tag to deploy (e.g. latest, v1.0.0, sha-abc1234)
TAG=latest

# --- Virtual host -------------------------------------------------------------
# Hostname used by the reverse proxy (nginx-proxy / VIRTUAL_HOST)
VIRTUAL_HOST=veaf.org

# --- Compose profiles ---------------------------------------------------------
# Comma-separated list of profiles to activate.
# Available profiles: staging (enables MailDev SMTP catch-all)
# Leave empty for production.
#COMPOSE_PROFILES=staging

# --- MailDev (staging profile) ------------------------------------------------
# MailDev web UI available at http://maildev.<VIRTUAL_HOST>
# In backend.env, set: MAIL_SERVER=maildev  MAIL_PORT=1025  MAIL_TLS=false
MAILDEV_WEB_USER=veaf
MAILDEV_WEB_PASS=CHANGE_ME
