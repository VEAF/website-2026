# Database
DATABASE_URL=postgresql+asyncpg://veaf:password@postgres:5432/veaf

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (defaults configured for MailDev in docker-compose)
MAIL_FROM=noreply@veaf.org
MAIL_SERVER=maildev
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_STARTTLS=false
MAIL_SSL_TLS=false

# External APIs
API_DCSSERVERBOT_URL=http://dcs.veaf.org:9876
API_TEAMSPEAK_URL=serverquery://ts.veaf.org:10011/?server_port=9987

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://veaf.localhost/auth/discord/callback
DISCORD_SUPPORT_URL=

# Discord Bot (voice channels)
# Requires bot intents: GUILDS, GUILD_VOICE_STATES (both non-privileged, always available)
# GUILD_MEMBERS intent is NOT required
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=

# App
APP_URL=http://localhost
UPLOAD_DIR=./uploads
